---
layout: null
permalink: /events.json
---
{% comment %}
Auto-generated events JSON for event map
Pulls coordinates from event_locations.yml
If location not found in event_locations.yml, coordinates are omitted
{% endcomment %}
[
{% for event in site.data.events %}
  {
    "event": "{{ event.event }}",
    "start": "{{ event.start }}",
    "end": "{{ event.end }}",
    "location": "{{ event.location }}",
    "link": "{{ event.link }}",
    "status": "{{ event.status }}"{% if event.image %},
    "image": "{{ event.image }}"{% endif %}{% comment %}
    Include coordinates if location exists in event_locations.yml
    {% endcomment %}{% if site.data.event_locations.locations[event.location] %},
    "latitude": "{{ site.data.event_locations.locations[event.location].latitude }}",
    "longitude": "{{ site.data.event_locations.locations[event.location].longitude }}"{% endif %}
  }{% unless forloop.last %},{% endunless %}
{% endfor %}
]
