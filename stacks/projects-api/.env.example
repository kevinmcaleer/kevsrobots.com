# Projects API — production environment variables

# Cloudflare Tunnel token
PROJECTS_TUNNEL_TOKEN=your-tunnel-token-here

# PostgreSQL (kevsrobots_cms database on dev03)
DATABASE_URL=postgresql+asyncpg://kev:your-password@192.168.2.3:5433/kevsrobots_cms

# Chatter JWT secret — must match chatter's SECRET_KEY
JWT_SECRET=your-chatter-secret-key

# CORS
CORS_ORIGINS=https://www.kevsrobots.com,https://projects.kevsrobots.com,http://localhost:4000,http://local.kevsrobots.com:4000

# NAS storage (same credentials as chatter)
NAS_HOST=192.168.2.200
NAS_USERNAME=kevsrobots
NAS_PASSWORD=your-nas-password
NAS_SHARE_NAME=chatter

# Salt used to hash anonymous client IPs when tracking downloads.
# Set this to a long random value (e.g. `openssl rand -hex 32`) and keep it
# stable across restarts so download dedup works. Raw IPs are NEVER stored
# or returned by the API — only the salted SHA-256 hash.
IP_HASH_SALT=change-me-to-a-long-random-string
