# postgres-backup configuration.
#
# Copy to ``.env`` and fill in the placeholders, then deploy with
# the wrapper script:
#
#     ./deploy.sh
#
# (or, manually: ``set -a; source .env; set +a;
#                 docker stack deploy -c docker-compose.prod.yml postgres-backup``)
#
# ``docker stack deploy`` does NOT auto-read ``.env`` the way
# ``docker-compose`` does — variables have to be in the shell
# environment at parse time. deploy.sh handles that for you.
#
# ─────────────────────────────────────────────────────────────────
# Credentials note
# ─────────────────────────────────────────────────────────────────
# Postgres username + password are NOT here on purpose. They live
# as Docker swarm secrets (postgres_user, postgres_password) and
# get mounted at /run/secrets/* inside the backup container.
# Confirm they exist before deploying:
#
#     docker secret ls | grep postgres_
#
# They were created with the postgres stack — should already be
# present. If they're missing, recreate via:
#
#     printf 'kev' | docker secret create postgres_user -
#     printf 'YOUR-PASSWORD' | docker secret create postgres_password -
#
# ═════════════════════════════════════════════════════════════════
# NAS / NFS share — REQUIRED
# ═════════════════════════════════════════════════════════════════

# LAN IP of the NAS that exposes the NFS share.
NAS_IP=192.168.2.10

# NFS export path on the NAS. The leading colon IS required
# by Docker for NFS volumes. Synology example: :/volume1/backups/postgres
# TrueNAS / Unraid example:                    :/mnt/tank/backups/postgres
NAS_EXPORT_PATH=:/volume1/backups/postgres

# NFS protocol version. Most modern NAS units speak v4. Drop to 3
# if your NAS only exports v3 (older Synology DSM, some QNAP).
NFS_VERSION=4

# ═════════════════════════════════════════════════════════════════
# Postgres connection — usually fine to leave as defaults
# ═════════════════════════════════════════════════════════════════

# Database name to back up.
POSTGRES_DB=kevsrobots_cms

# Hostname inside the swarm overlay network. Matches the alias the
# postgres service uses — see docker service inspect postgres_postgres_primary.
POSTGRES_HOST=postgres_primary

# Port the postgres service listens on inside the overlay
# (not the host-published port — that's 5433, but irrelevant here
# because we connect over the overlay, not via host networking).
POSTGRES_PORT=5432

# Name of the overlay network the postgres service uses. Find it
# with ``docker network ls | grep postgres``. Convention:
# ``<stackname>_default`` — so ``docker stack deploy postgres ...``
# produces ``postgres_default``.
POSTGRES_NETWORK=postgres_default

# ═════════════════════════════════════════════════════════════════
# Retention — defaults match the spec (14 daily + 4 weekly)
# ═════════════════════════════════════════════════════════════════

# How many daily backups to keep. 28 = 14 days at 12 h cadence.
DAILY_KEEP=28

# How many weekly snapshots to keep (Sundays 00:00 UTC).
WEEKLY_KEEP=4
