# kevsrobots status service — production environment variables.
# Copy this to .env and fill in the values on each production server.

# ---------------------------------------------------------------------
# Cloudflare Tunnel
# ---------------------------------------------------------------------
# Tunnel token, from Cloudflare Zero Trust → Tunnels → "status".
# Without this set, the cloudflared sidecar will fail to start and
# https://status.kevsrobots.com will be unreachable, although the
# container's local API still works on the host network.
STATUS_TUNNEL_TOKEN=your-tunnel-token-here

# ---------------------------------------------------------------------
# Monitored services
# ---------------------------------------------------------------------
# Comma-separated list of ``name=url`` pairs. ``name`` is the display
# label used by the API and dashboard; ``url`` is the /health endpoint
# to probe. If unset, the code defaults to the nine services named in
# issue #203 with best-guess URLs — confirm each one in production.
#
# The status service itself is included as a self-poll on 127.0.0.1 so
# the dashboard shows its own health alongside everything else.
STATUS_SERVICES=search=https://www.kevsrobots.com/search.json,stats=https://stats.kevsrobots.com/health,page_count=https://page-count.kevsrobots.com/health,random_facts=https://random-facts.kevsrobots.com/health,nibsy=https://nibsy.kevsrobots.com/health,courses=https://www.kevsrobots.com/learn/index.html,chatter=https://chatter.kevsrobots.com/health,projects=https://projects.kevsrobots.com/health,status=http://127.0.0.1:8210/health

# ---------------------------------------------------------------------
# Polling / retention tunables
# ---------------------------------------------------------------------
# How often to poll every service (minutes). Issue #203 says 15.
# Lower this only for testing — production should leave it at 15.
POLL_INTERVAL_MINUTES=15

# Per-check HTTP timeout (seconds). Probes slower than this are red.
POLL_TIMEOUT_SECONDS=5

# 200-but-slow threshold (seconds). 200s above this become amber.
AMBER_LATENCY_SECONDS=2

# How many days of history to keep. The daily vacuum job (03:30 UTC by
# default) deletes rows older than this. Issue #203 says 30.
RETENTION_DAYS=30

# ---------------------------------------------------------------------
# Storage
# ---------------------------------------------------------------------
# SQLite path inside the container. The docker-compose.prod.yml file
# bind-mounts host ./data → /data, so this stays at /data/status.db.
STATUS_DB_PATH=/data/status.db
