# kevsrobots status service — production environment variables.
# Copy this to .env and fill in the values on each production server.

# ---------------------------------------------------------------------
# Cloudflare Tunnel
# ---------------------------------------------------------------------
# Tunnel token, from Cloudflare Zero Trust → Tunnels → "status".
# Without this set, the cloudflared sidecar will fail to start and
# https://status.kevsrobots.com will be unreachable, although the
# container's local API still works on the host network.
STATUS_TUNNEL_TOKEN=your-tunnel-token-here

# ---------------------------------------------------------------------
# Monitored services
# ---------------------------------------------------------------------
# Comma-separated list of ``name=url`` pairs. ``name`` is the display
# label used by the API and dashboard; ``url`` is the /health endpoint
# to probe. If unset, the code defaults to the nine services named in
# issue #203 with best-guess URLs — confirm each one in production.
#
# The status service itself is included as a self-poll on 127.0.0.1 so
# the dashboard shows its own health alongside everything else.
# ``status`` polls itself via the public hostname so the check exercises
# the full app + cloudflared + Cloudflare chain, not just local uvicorn.
# ``stats`` uses ``/api/health`` (not ``/health``); ``page_count`` keeps
# the underscored subdomain it's deployed under (the hyphenated
# ``page-count`` host 404s and would read as amber/"degraded").
# NOTE: ``random_facts`` does NOT currently resolve (no DNS for the host)
# — it'll read red on the dashboard until the service is renamed or
# dropped from this list.
STATUS_SERVICES=search=https://search.kevsrobots.com/health,stats=https://stats.kevsrobots.com/api/health,page_count=https://page_count.kevsrobots.com/health,random_facts=https://random-facts.kevsrobots.com/health,nibsy=https://nibsy.kevsrobots.com/health,courses=https://courses.kevsrobots.com/health,chatter=https://chatter.kevsrobots.com/health,projects=https://projects.kevsrobots.com/health,status=https://status.kevsrobots.com/health

# ---------------------------------------------------------------------
# Polling / retention tunables
# ---------------------------------------------------------------------
# How often to poll every service (minutes). Issue #203 says 15.
# Lower this only for testing — production should leave it at 15.
POLL_INTERVAL_MINUTES=15

# Per-check HTTP timeout (seconds). Probes slower than this are red.
POLL_TIMEOUT_SECONDS=5

# 200-but-slow threshold (seconds). 200s above this become amber.
AMBER_LATENCY_SECONDS=2

# How many days of history to keep. The daily vacuum job (03:30 UTC by
# default) deletes rows older than this. Issue #203 says 30.
RETENTION_DAYS=30

# ---------------------------------------------------------------------
# Storage
# ---------------------------------------------------------------------
# SQLite path inside the container. The docker-compose.prod.yml file
# bind-mounts host ./data → /data, so this stays at /data/status.db.
STATUS_DB_PATH=/data/status.db

# ---------------------------------------------------------------------
# Network egress
# ---------------------------------------------------------------------
# Force IPv4 for outbound probes. The Pi sometimes brings IPv6 up
# without a working v6 default route after a power-cut — same problem
# the cloudflared sidecar's ``--edge-ip-version 4`` flag fixes. Without
# this every probe to a hostname with an AAAA record fails with
# ConnectError (ENETUNREACH). Default "1" (force v4). Set to "0" only
# if the Pi gains a working IPv6 default route and you want dual-stack.
STATUS_FORCE_IPV4=1

# External DNS resolver used for outbound probe hostname lookups. The
# status service should report on services as the *outside world* sees
# them — if you run a local Pi-hole / dnsmasq / router DNS that maps
# ``*.kevsrobots.com`` to a LAN IP (split-horizon DNS), every probe
# inside the Pi resolves to the wrong target. Querying 1.1.1.1 directly
# bypasses any local rewrite. IP literals + lookups for hosts the
# external resolver can't answer fall through to the system resolver.
# Disable with STATUS_DISABLE_EXTERNAL_DNS=1.
STATUS_DNS_SERVER=1.1.1.1
STATUS_DISABLE_EXTERNAL_DNS=0
