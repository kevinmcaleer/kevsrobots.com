# Nibsy API — production environment variables
# Copy this to .env and fill in the values on each production server.

# Cloudflare Tunnel token (from Zero Trust dashboard → Tunnels → nibsy)
NIBSY_TUNNEL_TOKEN=your-tunnel-token-here

# PostgreSQL connection string
DATABASE_URL=postgresql+asyncpg://nibsy:nibsy@192.168.2.1:5433/nibsy

# Allowed CORS origins (comma-separated)
CORS_ORIGINS=https://www.kevsrobots.com,https://nibsy.kevsrobots.com,http://localhost:4000

# Live site URL for remote ingestion
SITE_BASE_URL=https://www.kevsrobots.com

# Page count service URL for trending scores
PAGE_COUNT_URL=https://page_count.kevsrobots.com

# Daily ingest hour (UTC). Set to -1 to disable.
INGEST_SCHEDULE_HOUR=1

# Recommendation refresh cadence (days). Set to 0 to disable.
RECOMMENDATION_REFRESH_DAYS=14
