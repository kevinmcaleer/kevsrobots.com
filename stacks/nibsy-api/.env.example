# Nibsy API — production environment variables
# Copy this to .env and fill in the values on each production server.

# Cloudflare Tunnel token (from Zero Trust dashboard → Tunnels → nibsy)
NIBSY_TUNNEL_TOKEN=your-tunnel-token-here

# PostgreSQL connection string
DATABASE_URL=postgresql+asyncpg://nibsy:nibsy@192.168.2.1:5433/nibsy

# Allowed CORS origins (comma-separated)
CORS_ORIGINS=https://www.kevsrobots.com,https://nibsy.kevsrobots.com,http://localhost:4000

# Admin auth (#158). JWT_SECRET MUST match Chatter's SECRET_KEY and
# projects-api's JWT_SECRET — all three verify the same Chatter-signed
# tokens, so a mismatch makes every /api/admin/* call 401 "Not
# authenticated" (e.g. the /admin/nibsy/ regenerate buttons). Defaults to
# "changeme" if unset, which never validates a real token.
JWT_SECRET=change-me-to-match-chatter-and-projects-api
# Comma-separated usernames allowed to hit /api/admin/* (else 403).
ADMIN_USERNAMES=kev

# Live site URL for remote ingestion
SITE_BASE_URL=https://www.kevsrobots.com

# Pagecount database URL for trending scores (direct DB query, not HTTP)
PAGE_COUNT_URL=postgresql://kev:mysecretpassword@192.168.2.3:5433/pagecount

# Daily ingest hour (UTC). Set to -1 to disable.
INGEST_SCHEDULE_HOUR=1

# Recommendation refresh cadence (days). Set to 0 to disable.
RECOMMENDATION_REFRESH_DAYS=14
